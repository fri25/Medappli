# Ignore root files and folders that are not needed for Vercel serverless deployment
.git/
.gitignore
README.md
readme.md
CHANGELOG*
changelog*.md
doc/
docs/
tests/
test/
node_modules/
package-lock.json
npm-debug.log*

env/
*.log

# Remove vendor documentation, examples and tests
vendor/**/tests
vendor/**/Tests
vendor/**/test
vendor/**/docs
vendor/**/doc
vendor/**/examples
vendor/**/example
vendor/**/*.md
vendor/**/README*
vendor/**/CHANGELOG*
vendor/**/LICENSE*
vendor/**/.github/
vendor/**/.git/
vendor/**/phpunit*
vendor/**/composer*
vendor/**/Makefile
vendor/**/.travis.yml
vendor/**/.editorconfig
vendor/**/CONTRIBUTING*
vendor/**/.gitattributes
vendor/**/*.yml
vendor/**/*.yaml
vendor/**/psalm.xml
vendor**/phpstan*

# Remove app directories not needed for production
storage/
uploads/temp/
logs/
tmp/
