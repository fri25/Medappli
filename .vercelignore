# Ignorer les dossiers Git et IDE
.git/
.gitignore
.vscode/
.idea/

# Ignorer la documentation et les fichiers Markdown
doc/
docs/
README.md
readme.md
CHANGELOG*
changelog*.md
arch.md
vercel_build_analysis.md

# Ignorer les tests et outils de dev
tests/
test/
phpunit.xml
.phpunit.result.cache
package.json
package-lock.json
node_modules/

# Ignorer les scripts de build et logs
# build.sh doit être conservé pour que Vercel puisse l'exécuter
script.sh
build_log_v51.txt
*.log
logs/

# Ignorer les fichiers de base de données (déjà sur Aiven)
*.sql
medconnect_db.sql
database_complete.sql
database_temp.sql

# Ignorer le cache et les sessions locales
storage/cache/*
storage/sessions/*
storage/logs/*

# Ignorer les fichiers source Tailwind (on utilise le CDN)
src/

# Ignorer les fichiers d'environnement locaux
.env
.env.local
.env.*.local

# Ignorer les fichiers Composer inutiles après l'install
# (Vercel a besoin de composer.json pour le build, mais pas dans le bundle final)
composer.phar
composer-setup.php

# Ignorer les fichiers système OS
.DS_Store
Thumbs.db
