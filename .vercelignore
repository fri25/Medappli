# Ignore root files and folders that are not needed for Vercel serverless deployment
.git/
.gitignore
README.md
readme.md
CHANGELOG*
changelog*.md
doc/
docs/
tests/
test/
node_modules/
vendor/
package-lock.json
npm-debug.log*
*.log

env/
*.env
.env
.env.local
.env.*.local

# Remove vendor documentation, examples and tests
vendor/**/tests
vendor/**/Tests
vendor/**/test
vendor/**/docs
vendor/**/doc
vendor/**/examples
vendor/**/example
vendor/**/*.md
vendor/**/*.MD
vendor/**/README*
vendor/**/CHANGELOG*
vendor/**/LICENSE*
vendor/**/.github/
vendor/**/.git/
vendor/**/phpunit*
vendor/**/composer*
vendor/**/Makefile
vendor/**/.travis.yml
vendor/**/.editorconfig
vendor/**/CONTRIBUTING*
vendor/**/.gitattributes
vendor/**/.gitignore
vendor/**/*.yml
vendor/**/*.yaml
vendor/**/*.xml
vendor/**/*.dist
vendor/**/psalm.xml
vendor**/phpstan*
vendor/**/appveyor.yml
vendor/**/.gitlab-ci.yml
vendor/**/Dockerfile
vendor/**/Jenkinsfile
vendor/bin/**

# Remove app directories not needed for production
storage/
uploads/temp/
logs/
tmp/

# Database files
*.sql
*.db
*.sqlite

# Cache & session files
storage/cache/**
storage/sessions/**

# OS files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
build/
dist/
*.tar.gz
*.zip

# Local development
.composer/
.php-cs-fixer*
