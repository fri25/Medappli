RewriteEngine On

# Empêcher le téléchargement des fichiers PHP en s'assurant qu'ils sont exécutés
# Si PHP n'est pas activé, cela pourrait afficher le code source, 
# mais AddType application/x-httpd-php peut forcer le téléchargement si mal configuré.
# Sur XAMPP, on laisse généralement le serveur gérer le type MIME par défaut.

# Rediriger index.php vers le routeur pour éviter les boucles
RewriteRule ^index\.php$ api/index.php [L]

# Redirection des assets vers le dossier public
RewriteRule ^assets/(.*)$ public/assets/$1 [L]

# Redirection de toutes les requêtes vers api/index.php (le routeur)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ api/index.php [L]

# Cas de la racine
RewriteRule ^$ api/index.php [L]
