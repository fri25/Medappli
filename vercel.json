{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "excludeFiles": "{vendor/**/Test*/**,vendor/**/*.{md,txt},vendor/**/.git/**,vendor/**/.github/**,vendor/**/{doc,docs,examples}/**,node_modules/**,.git/**,doc/**,chatbot/**,migrations/**,scripts/**,tmp/**,logs/**,resources/**,src/**}"
    }
  },
  "rewrites": [
    {
      "source": "/root_scripts/(.*)",
      "destination": "/404"
    },
    {
      "source": "/config/(.*)",
      "destination": "/404"
    },
    {
      "source": "/includes/(.*)",
      "destination": "/404"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/public/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}