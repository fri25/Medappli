{
  "version": 2,
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "functions": {
    "api/api.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/public/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/api.php"
    }
  ]
}