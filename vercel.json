{
  "version": 2,
  "functions": {
    "api/*.php": { 
      "runtime": "vercel-php",
      "includeFiles": "{api/**,auth/**,config/**,includes/**,models/**,views/**,vendor/**,app/**,public/**}"
    },
    "index.php": { 
      "runtime": "vercel-php",
      "includeFiles": "{api/**,auth/**,config/**,includes/**,models/**,views/**,vendor/**,app/**,public/**}"
    },
    "*.php": { 
      "runtime": "vercel-php",
      "includeFiles": "{api/**,auth/**,config/**,includes/**,models/**,views/**,vendor/**,app/**,public/**}"
    }
  },
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/public/assets/$1" },
    { "source": "/(.*)", "destination": "/index.php" }
  ]
}
