{
  "version": 2,
  "buildCommand": "php scripts/cleanup-vendor.php",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": [
        "api/**",
        "auth/**",
        "config/**",
        "includes/**",
        "models/**",
        "views/**",
        "vendor/autoload.php",
        "vendor/composer/**",
        "vendor/vlucas/**",
        "vendor/google/**",
        "vendor/phpmailer/**",
        "vendor/guzzlehttp/**",
        "vendor/ralouphie/**",
        "vendor/psr/**",
        "vendor/symfony/**",
        "vendor/monolog/**",
        "vendor/phpoption/**",
        "vendor/graham-campbell/**",
        "vendor/paragonie/**",
        "vendor/phpseclib/**",
        "vendor/dompdf/**",
        "vendor/sabberworm/**",
        "vendor/phenx/**",
        "vendor/firebase/**"
      ],
      "excludeFiles": [
        "vendor/**/tests/**",
        "vendor/**/Tests/**",
        "vendor/**/test/**",
        "vendor/**/docs/**",
        "vendor/**/doc/**",
        "vendor/**/examples/**",
        "vendor/**/example/**",
        "vendor/**/*.md",
        "vendor/**/*.MD",
        "vendor/**/README*",
        "vendor/**/CHANGELOG*",
        "vendor/**/LICENSE*",
        "vendor/**/.github/**",
        "vendor/**/.git/**",
        "vendor/**/.travis.yml",
        "vendor/**/.travis.yaml",
        "vendor/**/.editorconfig",
        "vendor/**/Makefile",
        "vendor/**/phpunit*",
        "vendor/**/psalm*",
        "vendor/**/phpstan*",
        "vendor/**/composer.json",
        "vendor/**/composer.lock",
        "vendor/**/composer.phar",
        "vendor/**/.gitattributes",
        "vendor/**/.gitignore",
        "vendor/**/*.yml",
        "vendor/**/*.yaml",
        "vendor/**/CONTRIBUTING*",
        "vendor/**/INSTALL*",
        "vendor/**/BUILD*",
        "vendor/**/DEVELOPMENT*",
        "vendor/**/SECURITY*",
        "vendor/**/Dockerfile",
        "vendor/**/.gitlab-ci.yml",
        "vendor/**/appveyor.yml",
        "vendor/**/*.phar",
        "vendor/**/*.min.js.map",
        "vendor/**/*.css.map",
        "vendor/**/*.xml",
        "vendor/**/*.dist",
        "vendor/bin/**"
      ]
    }
  },
  "routes": [
    { "src": "\/(.*)", "dest": "\/api\/index.php" }
  ]
}
